{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2020"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "Bundler",
        "isolatedModules": true,
        "resolveJsonModule": true,
        "jsx": "react-jsx",
        "noEmit": true,
        "strict": false,
        "allowJs": false,
        "types": [
            "vite/client"
        ]
    },
    "include": [
        "src",
        "vite.config.js"
    ]
}